<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Intro -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="التطبيق يطلب صلاحيات ضرورية فقط"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:paddingBottom="12dp" />

        <!-- Permission 1: Microphone -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🎤"
                    android:textSize="24sp"
                    android:paddingEnd="12dp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="تسجيل الصوت"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary" />
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="علشان نسمع الصوت من الفيديو أو التطبيق ونترجمه\n\n✓ بلا تسجيل مخفي\n✓ بلا حفظ الصوت"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                android:paddingStart="36dp"
                android:paddingTop="4dp"
                android:lineSpacingExtra="4dp" />
        </LinearLayout>

        <!-- Permission 2: Overlay -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📺"
                    android:textSize="24sp"
                    android:paddingEnd="12dp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="عرض فوق التطبيقات"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary" />
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="علشان نعرض الترجمة شفاف فوق الفيديو أو التطبيق\n\n✓ Overlay شفاف بلا تفاعل\n✓ لا تشتت الانتباه"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                android:paddingStart="36dp"
                android:paddingTop="4dp"
                android:lineSpacingExtra="4dp" />
        </LinearLayout>

        <!-- Permission 3: Notifications -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🔔"
                    android:textSize="24sp"
                    android:paddingEnd="12dp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="الإشعارات"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary" />
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="إشعار دائم يخبرك إن الخدمة شغالة (قانوني لكل تطبيق يشتغل في الخلفية)\n\n✓ إشعار واحد فقط\n✓ مع زر إيقاف سريع"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                android:paddingStart="36dp"
                android:paddingTop="4dp"
                android:lineSpacingExtra="4dp" />
        </LinearLayout>

        <!-- Permission 4: Internet -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🌐"
                    android:textSize="24sp"
                    android:paddingEnd="12dp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="الإنترنت"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary" />
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="علشان نرسل النص لخوادم الترجمة\n\n✓ HTTPS مشفر (آمن)\n✓ بلا تتبع شخصي"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                android:paddingStart="36dp"
                android:paddingTop="4dp"
                android:lineSpacingExtra="4dp" />
        </LinearLayout>

        <!-- Privacy Notice -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            app:cardCornerRadius="8dp"
            app:cardBackgroundColor="@color/privacy_card_bg">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="🔒 خصوصيتك آمنة"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="@color/accent_green"
                    android:paddingBottom="4dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="التطبيق لا يطلب:\n❌ الموقع\n❌ جهات الاتصال\n❌ ملفاتك الشخصية\n❌ الكاميرا"
                    android:textSize="11sp"
                    android:textColor="@color/text_secondary"
                    android:lineSpacingExtra="2dp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>
