<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp">

    <!-- Header -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="انتهت فترة التجربة"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="@color/text_primary"
        android:gravity="center"
        android:paddingBottom="8dp" />

    <TextView
        android:id="@+id/tvUpgradeMessage"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="استخدمت 30 دقيقة اليوم"
        android:textSize="13sp"
        android:textColor="@color/text_secondary"
        android:gravity="center"
        android:paddingBottom="16dp"
        android:lineSpacingExtra="4dp" />

    <!-- PLUS Plan -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="2dp"
        app:cardBackgroundColor="@color/card_background">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingBottom="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="PLUS"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="$0.99/شهر"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="@color/accent_green" />
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="ترجمة غير محدود\n100+ لغة\nبدون إعلانات"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                android:lineSpacingExtra="4dp"
                android:paddingBottom="12dp" />

            <Button
                android:id="@+id/btnUpgradePlus"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:text="ترقِّ إلى PLUS"
                android:textSize="14sp"
                android:textStyle="bold"
                android:backgroundTint="@color/button_primary"
                android:textColor="@android:color/white" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- PREMIUM Plan -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="2dp"
        app:cardBackgroundColor="@color/card_premium_bg">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingBottom="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="PREMIUM"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@android:color/white" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="$2.99/شهر"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="@color/accent_orange" />
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="كل ميزات PLUS\nOffline translation\nCustom themes"
                android:textSize="12sp"
                android:textColor="@android:color/white"
                android:lineSpacingExtra="4dp"
                android:paddingBottom="12dp" />

            <Button
                android:id="@+id/btnUpgradePremium"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:text="ترقِّ إلى PREMIUM"
                android:textSize="14sp"
                android:textStyle="bold"
                android:backgroundTint="@color/button_secondary"
                android:textColor="@color/text_primary" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Later -->
    <Button
        android:id="@+id/btnRemindLater"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:text="لاحقاً"
        android:textSize="14sp"
        android:backgroundTint="@android:color/transparent"
        android:textColor="@color/text_secondary" />

</LinearLayout>
